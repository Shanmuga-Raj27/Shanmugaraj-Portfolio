    replacement_chunks {
      replacement_content: "import { motion } from \'motion/react\';\nimport { BookOpen, Star, GitFork, ExternalLink } from \'lucide-react\';\n\nconst projects = [\n  {\n    title: \'Sentinel\',\n    description: \'An AI-driven threat detection engine that analyzes network traffic patterns to identify anomalies before they escalate. Built with a focus on low latency and secure data processing.\',\n    tech: [\'Python\', \'LLMs\', \'FastAPI\'],\n    stars: 128,\n    forks: 34\n  },\n  {\n    title: \'Nexus-RAG\',\n    description: \'A modular Retrieval-Augmented Generation framework. Connects disparate knowledge bases, providing a unified search interface via intelligent vector embeddings.\',\n    tech: [\'React\', \'Supabase\', \'Docker\'],\n    stars: 256,\n    forks: 89\n  },\n  {\n    title: \'Orbit\',\n    description: \'High-performance, real-time data pipeline architecture using WebSockets to synchronize massive datasets across distributed microservices.\',\n    tech: [\'WebSockets\', \'Python\', \'Redis\'],\n    stars: 64,\n    forks: 12\n  }\n];\n\nexport default function Projects() {\n  return (\n    <section id=\"projects\" className=\"max-w-4xl mx-auto px-6 relative z-10\">\n      <motion.div\n        initial={{ opacity: 0, y: 20 }}\n        whileInView={{ opacity: 1, y: 0 }}\n        viewport={{ once: true, margin: \"-100px\" }}\n        transition={{ duration: 0.6 }}\n      >\n        <div className=\"flex items-center gap-3 mb-8\">\n           <h3 className=\"font-mono text-2xl text-soft-white font-bold\">\n             <span className=\"text-neon mr-2\">./</span>execute_projects.sh\n           </h3>\n        </div>\n\n        <div className=\"grid md:grid-cols-2 gap-6\">\n          {projects.map((project, index) => (\n            <motion.div\n              key={project.title}\n              initial={{ opacity: 0, y: 20 }}\n              whileInView={{ opacity: 1, y: 0 }}\n              viewport={{ once: true }}\n              transition={{ delay: index * 0.1, duration: 0.5 }}\n              className=\"glass-card rounded-lg p-6 hover:border-neon/30 transition-colors duration-300 group relative flex flex-col\"\n            >\n              <div className=\"flex items-start justify-between mb-4\">\n                <div className=\"flex items-center gap-2\">\n                  <BookOpen size={18} className=\"text-muted-gray group-hover:text-soft-white transition-colors\" />\n                  <a href=\"#\" className=\"font-mono text-lg font-bold text-neon hover:underline\">\n                    {project.title}\n                  </a>\n                </div>\n                <div className=\"flex items-center gap-2 mt-1\">\n                   {project.tech[0] === \'Python\' && <div className=\"w-2.5 h-2.5 rounded-full bg-blue-500\" />}\n                   {project.tech[0] === \'React\' && <div className=\"w-2.5 h-2.5 rounded-full bg-cyan-400\" />}\n                   {project.tech[0] === \'WebSockets\' && <div className=\"w-2.5 h-2.5 rounded-full bg-yellow-400\" />}\n                </div>\n              </div>\n              \n              <p className=\"text-muted-gray text-sm leading-relaxed mb-6 font-sans flex-grow\">\n                {project.description}\n              </p>\n              \n              <div className=\"flex items-center justify-between text-xs font-mono text-muted-gray pt-4 border-t border-white/5\">\n                <div className=\"flex items-center gap-4\">\n                  <div className=\"flex flex-wrap gap-2\">\n                    {project.tech.map(tech => (\n                      <span key={tech} className=\"px-2 py-1 rounded bg-white/5 border border-white/5 text-soft-white\">{tech}</span>\n                    ))}\n                  </div>\n                </div>\n                <div className=\"flex items-center gap-3\">\n                  <span className=\"flex items-center gap-1 hover:text-neon cursor-pointer transition-colors\"><Star size={14} /> {project.stars}</span>\n                  <span className=\"flex items-center gap-1 hover:text-neon cursor-pointer transition-colors\"><GitFork size={14} /> {project.forks}</span>\n                </div>\n              </div>\n            </motion.div>\n          ))}\n        </div>\n      </motion.div>\n    </section>\n  );\n}\n"
    }
