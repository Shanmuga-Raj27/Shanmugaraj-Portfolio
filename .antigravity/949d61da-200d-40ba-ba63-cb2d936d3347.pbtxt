y-0 group-hover:opacity-100 transition-opacity duration-300\" />\n              <skill.icon className=\"text-muted-gray group-hover:text-neon group-hover:drop-shadow-[0_0_8px_rgba(0,255,156,0.6)] transition-all duration-300 mb-3\" size={28} />\n              <span className=\"font-mono text-xs font-medium text-soft-white tracking-wide\">{skill.name}</span>\n            </motion.div>\n          ))}\n        </div>\n      </motion.div>\n    </section>\n  );\n}\n"
