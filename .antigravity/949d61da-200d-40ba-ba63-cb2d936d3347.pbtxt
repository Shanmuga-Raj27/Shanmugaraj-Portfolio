        target_content: "import { motion } from \'motion/react\';\nimport { Send, Mail, Github, Linkedin, Twitter } from \'lucide-react\';\n\nexport default function Contact() {\n  return (\n    <section id=\"contact\" className=\"max-w-4xl mx-auto px-6 relative z-10\">\n      <motion.div\n        initial={{ opacity: 0, y: 20 }}\n        whileInView={{ opacity: 1, y: 0 }}\n        viewport={{ once: true, margin: \"-100px\" }}\n        transition={{ duration: 0.6 }}\n        className=\"text-center\"\n      >\n        <h3 className=\"font-mono text-3xl text-soft-white font-bold mb-6\">Initiate Handshake</h3>\n        <p className=\"text-muted-gray mb-10 max-w-lg mx-auto font-sans text-lg\">\n          Currently exploring new opportunities and open-source collaborations. Feel free to ping my inbox.\n        </p>\n        \n        <a \n          href=\"mailto:rshanmugaraj11@gmail.com\"\n          className=\"inline-flex items-center gap-2 px-8 py-4 rounded-lg bg-neon/10 border border-neon/50 text-neon font-mono font-medium hover:bg-neon hover:text-black hover:shadow-[0_0_20px_rgba(0,255,156,0.5)] transition-all duration-300\"\n        >\n          <Send size={18} />\n          Send Transmission\n        </a>\n        \n        <div className=\"flex items-center justify-center gap-6 mt-16 pt-8 border-t border-white/5\">\n          <a href=\"#\" className=\"text-muted-gray hover:text-soft-white transition-colors\">\n            <Github size={24} />\n          </a>\n          <a href=\"#\" className=\"text-muted-gray hover:text-[#0077b5] transition-colors\">\n            <Linkedin size={24} />\n          </a>\n          <a href=\"#\" className=\"text-muted-gray hover:text-[#1DA1F2] transition-colors\">\n            <Twitter size={24} />\n          </a>\n          <a href=\"mailto:rshanmugaraj11@gmail.com\" className=\"text-muted-gray hover:text-accent-red transition-colors\">\n            <Mail size={24} />\n          </a>\n        </div>\n        \n        <div className=\"mt-8 mb-16 text-xs text-muted-gray/50 font-mono\">\n          <p>&copy; {new Date().getFullYear()} Shanmugaraj. Root privileges required.</p>\n        </div>\n      </motion.div>\n    </section>\n  );\n}"
        replacement_content: "import { motion } from \'motion/react\';\nimport { Send, Mail, Github, Linkedin, Twitter } from \'lucide-react\';\n\nexport default function Contact() {\n  return (\n    <>\n      <section id=\"contact\" className=\"max-w-4xl mx-auto px-6 relative z-10 w-full mb-32\">\n        <motion.div\n          initial={{ opacity: 0, y: 20 }}\n          whileInView={{ opacity: 1, y: 0 }}\n          viewport={{ once: true, margin: \"-100px\" }}\n          transition={{ duration: 0.6 }}\n          className=\"text-center\"\n        >\n          <h3 className=\"font-mono text-3xl text-soft-white font-bold mb-6\">Initiate Handshake</h3>\n          <p className=\"text-muted-gray mb-10 max-w-lg mx-auto font-sans text-lg\">\n            Currently exploring new opportunities and open-source collaborations. Feel free to ping my inbox.\n          </p>\n          \n          <a \n            href=\"mailto:rshanmugaraj11@gmail.com\"\n            className=\"inline-flex items-center gap-2 px-8 py-4 rounded-lg bg-neon/10 border border-neon/50 text-neon font-mono font-medium hover:bg-neon hover:text-black hover:shadow-[0_0_20px_rgba(0,255,156,0.5)] transition-all duration-300\"\n          >\n            <Send size={18} />\n            Send Transmission\n          </a>\n          \n          <div className=\"flex items-center justify-center gap-6 mt-16\">\n            <a href=\"#\" className=\"text-muted-gray hover:text-soft-white transition-colors\">\n              <Github size={24} />\n            </a>\n            <a href=\"#\" className=\"text-muted-gray hover:text-[#0077b5] transition-colors\">\n              <Linkedin size={24} />\n            </a>\n            <a href=\"#\" className=\"text-muted-gray hover:text-[#1DA1F2] transition-colors\">\n              <Twitter size={24} />\n            </a>\n            <a href=\"mailto:rshanmugaraj11@gmail.com\" className=\"text-muted-gray hover:text-accent-red transition-colors\">\n              <Mail size={24} />\n            </a>\n          </div>\n        </motion.div>\n      </section>\n\n      <footer className=\"h-12 border-t border-white/5 px-6 md:px-10 flex flex-col md:flex-row items-center justify-between text-[10px] font-mono text-muted-gray uppercase tracking-widest bg-matte relative z-20 w-full gap-2\">\n        <div className=\"flex space-x-6\">\n          <span>Github: <span className=\"text-soft-white\">@shanmugaraj</span></span>\n          <span>Status: <span className=\"text-neon\">Available for projects</span></span>\n        </div>\n        <div>\n          <span>Built with React & Python Logic</span>\n        </div>\n      </footer>\n    </>\n  );\n}"
