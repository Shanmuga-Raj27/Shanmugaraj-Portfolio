        target_content: "export default function Hero() {\n  return (\n    <section id=\"hero\" className=\"min-h-screen flex items-center justify-center pt-24 px-6 relative z-10\">\n      <div className=\"max-w-4xl mx-auto text-center flex flex-col items-center\">\n        \n        <motion.div\n           initial={{ scale: 0.8, opacity: 0 }}\n           animate={{ scale: 1, opacity: 1 }}\n           transition={{ duration: 0.8, ease: \"easeOut\" }}\n           className=\"relative mb-8\"\n        >\n          <div className=\"absolute inset-0 bg-neon rounded-full blur-xl opacity-20\"></div>\n          <div className=\"w-32 h-32 rounded-full border-2 border-neon p-1 shadow-[0_0_15px_rgba(0,255,156,0.3)] relative group\">\n            <div className=\"w-full h-full rounded-full bg-[#1a1a1a] flex items-center justify-center overflow-hidden\">\n               <div className=\"w-full h-full bg-gradient-to-br from-neon/20 to-matte opacity-80 group-hover:opacity-100 transition-opacity duration-500\"></div>\n               <span className=\"absolute text-3xl font-mono opacity-50 text-soft-white group-hover:scale-110 transition-transform duration-500\">SR</span>\n            </div>\n          </div>\n        </motion.div>\n\n        <motion.h1 \n          initial={{ y: 20, opacity: 0 }}\n          animate={{ y: 0, opacity: 1 }}\n          transition={{ duration: 0.6, delay: 0.2 }}\n          className=\"text-5xl md:text-6xl font-bold tracking-tight mb-4 text-soft-white\"\n          style={{ fontFamily: \"\'Courier New\', monospace\" }}\n        >\n          Shanmugaraj\n        </motion.h1>\n\n        <motion.h2\n          initial={{ y: 20, opacity: 0 }}\n          animate={{ y: 0, opacity: 1 }}\n          transition={{ duration: 0.6, delay: 0.3 }}\n          className=\"text-xl md:text-2xl text-neon font-mono mb-6 tracking-wide\"\n        >\n          Python &bull; AI &bull; Full Stack Developer\n        </motion.h2>\n\n        <motion.p\n          initial={{ y: 20, opacity: 0 }}\n          animate={{ y: 0, opacity: 1 }}\n          transition={{ duration: 0.6, delay: 0.4 }}\n          className=\"text-muted-gray mt-3 max-w-md mx-auto mb-10 text-sm leading-relaxed font-sans\"\n        >\n          Building intelligent and secure software systems with a focus on ethical AI and robust infrastructure.\n        </motion.p>\n        \n        <motion.div\n          initial={{ y: 20, opacity: 0 }}\n          animate={{ y: 0, opacity: 1 }}\n          transition={{ duration: 0.6, delay: 0.6 }}\n          className=\"w-full relative\"\n        >\n          <TerminalTyping />\n        </motion.div>\n\n        <motion.div\n          initial={{ y: 20, opacity: 0 }}\n          animate={{ y: 0, opacity: 1 }}\n          transition={{ duration: 0.6, delay: 0.8 }}\n          className=\"flex items-center gap-4\"\n        >\n          <a href=\"#projects\" className=\"px-8 py-3 rounded bg-white border border-white text-matte font-mono text-sm uppercase tracking-wider font-semibold hover:bg-transparent hover:text-white transition-all duration-300\">\n            View Work\n          </a>\n          <a href=\"#contact\" className=\"px-8 py-3 rounded bg-transparent border border-neon/50 text-neon font-mono text-sm uppercase tracking-wider hover:bg-neon/10 hover:border-neon hover:glow-neon transition-all duration-300\">\n            Initialize Contact\n          </a>\n        </motion.div>\n\n      </div>\n    </section>\n  );\n}"
        replacement_content: "export default function Hero() {\n  return (\n    <section id=\"hero\" className=\"w-full relative z-10 pt-20 pb-8\">\n      <div className=\"flex flex-col xl:flex-row items-center xl:items-start gap-8 mb-10 w-full text-center xl:text-left\">\n        \n        <motion.div\n           initial={{ scale: 0.8, opacity: 0 }}\n           animate={{ scale: 1, opacity: 1 }}\n           transition={{ duration: 0.8, ease: \"easeOut\" }}\n           className=\"relative shrink-0\"\n        >\n          <div className=\"absolute inset-0 bg-neon rounded-full blur-xl opacity-20\"></div>\n          <div className=\"w-32 h-32 rounded-full border-2 border-neon p-1 shadow-[0_0_15px_rgba(0,255,156,0.3)] relative group\">\n            <div className=\"w-full h-full rounded-full bg-[#1a1a1a] flex items-center justify-center overflow-hidden\">\n               <div className=\"w-full h-full bg-gradient-to-br from-neon/20 to-matte opacity-80 group-hover:opacity-100 transition-opacity duration-500\"></div>\n               <span className=\"absolute text-3xl font-mono opacity-50 text-soft-white group-hover:scale-110 transition-transform duration-500\">SR</span>\n            </div>\n          </div>\n        </motion.div>\n\n        <div>\n          <motion.h1 \n            initial={{ y: 20, opacity: 0 }}\n            animate={{ y: 0, opacity: 1 }}\n            transition={{ duration: 0.6, delay: 0.2 }}\n            className=\"text-5xl md:text-6xl font-bold tracking-tight mb-4 text-soft-white\"\n            style={{ fontFamily: \"\'Courier New\', monospace\" }}\n          >\n            Shanmugaraj\n          </motion.h1>\n\n          <motion.h2\n            initial={{ y: 20, opacity: 0 }}\n            animate={{ y: 0, opacity: 1 }}\n            transition={{ duration: 0.6, delay: 0.3 }}\n            className=\"text-xl md:text-2xl text-neon font-mono mb-4 tracking-wide\"\n          >\n            Python &bull; AI &bull; Full Stack Developer\n          </motion