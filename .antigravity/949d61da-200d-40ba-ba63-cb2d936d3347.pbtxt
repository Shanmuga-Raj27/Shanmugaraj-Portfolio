  file_change {
    absolute_path_uri: "file:///src/components/Hero.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useEffect, useState } from \'react\';\nimport { motion } from \'motion/react\';\n\nconst lines = [\n  \"> Super_User_Do\",\n  \"> Learning systems deeply...\",\n  \"> Building ethical AI systems...\"\n];\n\nfunction TerminalTyping() {\n  const [displayedLines, setDisplayedLines] = useState<string[]>([]);\n  const [currentLineIndex, setCurrentLineIndex] = useState(0);\n  const [currentCharIndex, setCurrentCharIndex] = useState(0);\n\n  useEffect(() => {\n    if (currentLineIndex >= lines.length) return;\n\n    const line = lines[currentLineIndex];\n\n    if (currentCharIndex < line.length) {\n      const timeout = setTimeout(() => {\n        setCurrentCharIndex((prev) => prev + 1);\n      }, Math.random() * 30 + 30); // Random typing speed between 30-60ms\n      return () => clearTimeout(timeout);\n    } else {\n      const timeout = setTimeout(() => {\n        setDisplayedLines((prev) => [...prev, line]);\n        setCurrentLineIndex((prev) => prev + 1);\n        setCurrentCharIndex(0);\n      }, 500); // Wait half a second before next line\n      return () => clearTimeout(timeout);\n    }\n  }, [currentLineIndex, currentCharIndex]);\n\n  return (\n    <div className=\"font-mono text-sm text-neon/80 bg-black/40 border border-white/5 rounded p-4 h-32 w-full max-w-lg mb-8 mx-auto flex flex-col justify-start items-start space-y-1 relative overflow-hidden shadow-inner\">\n      <div className=\"absolute top-0 left-0 w-full h-8 bg-gradient-to-b from-white/5 to-transparent flex items-center px-4 space-x-2\">\n        <div className=\"w-2 h-2 rounded-full bg-accent-red/50\"></div>\n        <div className=\"w-2 h-2 rounded-full bg-yellow-500/50\"></div>\n        <div className=\"w-2 h-2 rounded-full bg-deep-green/50\"></div>\n      </div>\n      <div className=\"pt-6 text-left w-full pl-2\">\n        {displayedLines.map((line, i) => (\n          <div key={i} className=\"text-muted-gray\">{line}</div>\n        ))}\n        {currentLineIndex < lines.length && (\n           <div className=\"text-neon flex items-center\">\n             <span>{lines[currentLineIndex].substring(0, currentCharIndex)}</span>\n             <motion.span \n              animate={{ opacity: [1, 0, 1] }} \n              transition={{ repeat: Infinity, duration: 0.8 }}\n              className=\"inline-block w-2-5 h-4 bg-neon ml-1\" \n             >\n               _\n             </motion.span>\n           </div>\n        )}\n        {currentLineIndex >= lines.length && (\n           <div className=\"text-neon flex items-center\">\n             <span>&gt; </span>\n             <motion.span \n              animate={{ opacity: [1, 0, 1] }} \n              transition={{ repeat: Infinity, duration: 0.8 }}\n              className=\"inline-block w-2-5 h-4 bg-neon ml-1\" \n             >\n               _\n             </motion.span>\n           </div>\n        )}\n      </div>\n    </div>\n  );\n}\n\nexport default function Hero() {\n  return (\n    <section id=\"hero\" className=\"min-h-screen flex items-center justify-center pt-24 px-6 relative z-10\">\n      <div className=\"max-w-4xl mx-auto text-center flex flex-col items-center\">\n        \n        <motion.div\n           initial={{ scale: 0.8, opacity: 0 }}\n           animate={{ scale: 1, opacity: 1 }}\n           transition={{ duration: 0.8, ease: \"easeOut\" }}\n           className=\"relative mb-8\"\n        >\n          <div className=\"w-32 h-32 rounded-full border-2 border-neon flex items-center justify-center glow-neon overflow-hidden bg-matte group\">\n             {/* Using a minimalist initial vector for avatar */}\n             <span className=\"font-mono text-4xl text-neon group-hover:scale-110 transition-transform duration-500\">SR</span>\n             <div className=\"absolute inset-0 bg-neon/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500\" />\n          </div>\n        </motion.div>\n\n        <motion.h1 \n          initial={{ y: 20, opacity: 0 }}\n          animate={{ y: 0, opacity: 1 }}\n          transition={{ duration: 0.6, delay: 0.2 }}\n          className=\"font-mono text-4xl md:text-6xl font-bold tracking-tight text-soft-white mb-4\"\n        >\n          Shanmugaraj\n        </motion.h1>\n\n        <motion.h2\n          initial={{ y: 20, opacity: 0 }}\n          animate={{ y: 0, opacity: 1 }}\n          transition={{ duration: 0.6, delay: 0.3 }}\n          className=\"text-xl md:text-2xl text-deep-green font-medium mb-6 font-sans tracking-wide\"\n        >\n          Python &bull; AI &bull; Full Stack Developer\n        </motion.h2>\n\n        <motion.p\n          initial={{ y: 20, opacity: 0 }}\n          animate={{ y: 0, opacity: 1 }}\n          transition={{ duration: 0.6, delay: 0.4 }}\n          className=\"text-muted-gray text-lg max-w-2xl mx-auto mb-10 font-sans font-light\"\n        >\n          Building intelligent and secure software systems.\n        </motion.p>\n        \n        <motion.div\n          initial={{ y: 20, opacity: 0 }}\n          animate={{ y: 0, opacity: 1 }}\n          transition={{ duration: 0.6, delay: 0.6 }}\n          className=\"w-full relative\"\n        >\n          <TerminalTyping />\n        </motion.div>\n\n        <motion.div\n          initial={{ y: 20, opacity: 0 }}\n          animate={{ y: 0, opacity: 1 }}\n          transition={{ duration: 0.6, delay: 0.8 }}\n          className=\"flex items-center gap-4\"\n        >\n          <a href=\"#projects\" className=\"px-8 py-3 rounded bg-white border border-white text-matte font-mono text-sm uppercase tracking-wider font-semibold hover:bg-transparent hover:text-white transition-all duration-300\">\n            View Work\n          </a>\n          <a href=\"#contact\" className=\"px-8 py-3 rounded bg-transparent border border-neon/50 text-neon font-mono text-sm uppercase tracking-wider hover:bg-neon/10 hover:border-neon hover:glow-neon transition-all duration-300\">\n            Initialize Contact\n          </a>\n        </motion.div>\n\n      </div>\n    </section>\n  );\n}\n"
    }
