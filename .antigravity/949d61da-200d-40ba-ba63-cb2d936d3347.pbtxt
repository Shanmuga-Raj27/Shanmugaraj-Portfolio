    replacement_chunks {
      target_content: "import { motion } from \'motion/react\';\nimport { ShieldCheck } from \'lucide-react\';\n\nexport default function Philosophy() {\n  return (\n    <section id=\"philosophy\" className=\"max-w-4xl mx-auto px-6 relative z-10\">\n      <motion.div\n        initial={{ opacity: 0, scale: 0.98 }}\n        whileInView={{ opacity: 1, scale: 1 }}\n        viewport={{ once: true, margin: \"-100px\" }}\n        transition={{ duration: 0.6 }}\n        className=\"glass-card rounded-xl p-8 md:p-12 border-t border-neon/30 relative overflow-hidden\"\n      >\n        <div className=\"absolute -top-10 -right-10 w-40 h-40 bg-deep-green/10 blur-[80px] rounded-full pointer-events-none\" />\n        \n        <div className=\"flex items-center gap-4 mb-6\">\n          <div className=\"w-10 h-10 rounded-full bg-neon/10 flex items-center justify-center border border-neon/20 text-neon\">\n            <ShieldCheck size={20} />\n          </div>\n          <h3 className=\"font-mono text-xl md:text-2xl text-soft-white font-bold\">Open Source & Security</h3>\n        </div>\n        \n        <blockquote className=\"border-l-2 border-neon pl-6 py-2 my-8 font-mono text-deep-green/80 italic text-lg leading-relaxed\">\n          \"Security is not a feature you append; it\'s the foundation upon which resilient systems are built.\"\n        </blockquote>\n        \n        <div className=\"space-y-4 text-muted-gray text-base leading-relaxed font-sans\">\n          <p>\n            I advocate for <strong className=\"text-soft-white font-medium\">open-source transparency</strong>. The strongest systems are forged in the light, scrutinized by the community, and iteratively hardened against emerging threats.\n          </p>\n          <p>\n            As software eats the world, integrating Artificial Intelligence responsibly means implementing <strong className=\"text-neon/80 font-medium\">guardrails first</strong>. From securing API endpoints with robust rate-limiting to sandboxing ML execution environments, ethical engineering requires continuous vigilance.\n          </p>\n        </div>\n      </motion.div>\n    </section>\n  );\n}"
      replacement_content: "import { motion } from \'motion/react\';\n\nexport default function Philosophy() {\n  return (\n    <section id=\"philosophy\" className=\"max-w-4xl mx-auto px-6 relative z-10 w-full\">\n      <motion.div\n        initial={{ opacity: 0, scale: 0.98 }}\n        whileInView={{ opacity: 1, scale: 1 }}\n        viewport={{ once: true, margin: \"-100px\" }}\n        transition={{ duration: 0.6 }}\n        className=\"grid grid-cols-1 md:grid-cols-2 gap-4\"\n      >\n        <div className=\"p-6 border border-white/5 bg-[#080808] rounded-xl hover:border-white/10 transition-colors\">\n          <span className=\"text-[10px] uppercase tracking-widest text-[#888888] mb-3 block font-mono\">Security Philosophy</span>\n          <p className=\"text-sm text-[#EDEDED] leading-relaxed\">\n            Prioritizing encryption, least privilege, and adversarial testing in every layer of development. Security is not a feature you append; it\'s the foundation upon which resilient systems are built.\n          </p>\n        </div>\n        <div className=\"p-6 border border-white/5 bg-[#080808] rounded-xl hover:border-white/10 transition-colors\">\n          <span className=\"text-[10px] uppercase tracking-widest text-[#888888] mb-3 block font-mono\">Open Source</span>\n          <p className=\"text-sm text-[#EDEDED] leading-relaxed\">\n            Active contributor to privacy-focused tools and AI governance frameworks. I advocate for open-source transparency where the strongest systems are forged in the light.\n          </p>\n        </div>\n      </motion.div>\n    </section>\n  );\n}"
    }
